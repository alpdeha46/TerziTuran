@using TerziTuran.Web.Extensions
@model IEnumerable<Payment>
@{ ViewData["Title"] = "Ödemeler"; }
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
    <div class="text-secondary">Atölyedeki tahsilat hareketlerini tek listede yönetin.</div>
    <a asp-action="Create" class="btn btn-gold">Yeni Ödeme</a>
</div>
<div class="card soft-card">
    <div class="table-responsive">
        <table class="table tt-table align-middle">
            <thead><tr><th>Sipariş</th><th>Müşteri</th><th>Tutar</th><th>Tip</th><th>Tarih</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="Sipariş">@item.Order?.Title</td>
                    <td data-label="Müşteri">@item.Order?.Customer?.FullName</td>
                    <td data-label="Tutar">@item.Amount.ToString("N0") TL</td>
                    <td data-label="Tip">@item.PaymentType.GetDisplayName()</td>
                    <td data-label="Tarih">@item.PaymentDate.ToString("dd.MM.yyyy")</td>
                    <td class="text-end"><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Detay</a> <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Düzenle</a> <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Sil</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
