@model Payment
<div class="card soft-card"><form method="post" class="row g-3">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="col-md-6"><label class="form-label">Sipariş</label><select asp-for="OrderId" asp-items="ViewBag.Orders" class="form-select"></select></div><div class="col-md-3"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" class="form-control" /></div><div class="col-md-3"><label asp-for="PaymentType" class="form-label"></label><select asp-for="PaymentType" asp-items="Html.GetEnumSelectList<PaymentType>()" class="form-select"></select></div><div class="col-md-4"><label asp-for="PaymentDate" class="form-label"></label><input asp-for="PaymentDate" type="date" class="form-control" /></div><div class="col-md-8"><label asp-for="Note" class="form-label"></label><input asp-for="Note" class="form-control" /></div><div class="col-12 d-flex gap-2"><button class="btn btn-gold">Kaydet</button><a asp-action="Index" class="btn btn-outline-dark">İptal</a></div></form></div><partial name="_ValidationScriptsPartial" />
