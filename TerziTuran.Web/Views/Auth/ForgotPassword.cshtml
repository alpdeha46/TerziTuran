@model ForgotPasswordViewModel
@{ ViewData["Title"] = "Şifre Sıfırlama"; }
<section class="auth-shell">
    <div class="auth-card single">
        <div class="auth-form-panel w-100">
            <img class="auth-form-logo" src="~/images/terzituran-mark.svg" alt="" />
            <h2>Şifre Sıfırlama</h2>
            <p class="text-secondary">Hesabınıza bağlı e-posta adresini girin. Güvenlik nedeniyle kayıt durumu açıklanmaz.</p>
            <form asp-action="ForgotPassword" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-12"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /><span asp-validation-for="Email" class="text-danger"></span></div>
                <div class="col-12 d-grid"><button class="btn btn-gold">Talep Gönder</button></div>
                <div class="col-12 text-center"><a asp-action="Login">Giriş ekranına dön</a></div>
            </form>
        </div>
    </div>
</section>
<partial name="_ValidationScriptsPartial" />
