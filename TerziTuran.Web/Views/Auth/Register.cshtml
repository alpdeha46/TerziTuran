@model RegisterViewModel
@{ ViewData["Title"] = "Müşteri Kaydı"; }
<section class="auth-shell">
    <div class="auth-card">
        <div class="auth-hero">
            <img class="auth-logo" src="~/images/terzituran-wordmark.svg" alt="Terzi Turan" />
            <div class="auth-hero-copy">
            <span class="auth-kicker">Yeni müşteri hesabı</span>
            <h1>Kendi müşteri portalınızı <em>oluşturun.</em></h1>
            <p>Ölçü, tamir ve yeni dikim siparişlerinizi doğrudan atölye ekibine iletin. Kayıt olan müşteri, sadece kendi panelini görür.</p>
            <div class="hero-pills">
                <span>Dikim takibi</span>
                <span>Tamir talepleri</span>
                <span>Durum bildirimleri</span>
            </div>
            </div>
        </div>
        <div class="auth-form-panel">
            <img class="auth-form-logo" src="~/images/terzituran-mark.svg" alt="" />
            <h2>Üye olun</h2>
            <p class="text-secondary">Bilgilerinizi girerek güvenli hesabınızı açın.</p>
            <form asp-action="Register" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="col-md-6"><label asp-for="FullName" class="form-label"></label><input asp-for="FullName" class="form-control" autocomplete="name" placeholder="Örn: Ayşe Yılmaz" /><span asp-validation-for="FullName" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="Username" class="form-label"></label><input asp-for="Username" class="form-control" autocomplete="username" placeholder="Örn: ayseyilmaz" /><span asp-validation-for="Username" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" autocomplete="email" placeholder="ornek@eposta.com" /><span asp-validation-for="Email" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="Phone" class="form-label"></label><input asp-for="Phone" class="form-control" autocomplete="tel" placeholder="05xx xxx xx xx" /><span asp-validation-for="Phone" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="Password" class="form-label"></label><input asp-for="Password" class="form-control password-strength-source" autocomplete="new-password" /><div class="password-meter"><span></span></div><span asp-validation-for="Password" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="ConfirmPassword" class="form-label"></label><input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" /><span asp-validation-for="ConfirmPassword" class="text-danger"></span></div>
                <div class="col-12 security-note"><i class="fa-solid fa-shield-halved"></i> En az 10 karakter; büyük/küçük harf, rakam ve özel karakter kullanın.</div>
                <div class="col-12 d-grid"><button class="btn btn-gold">Güvenli Hesabımı Oluştur</button></div>
                <div class="col-12 text-center"><a asp-action="Login">Zaten hesabım var</a></div>
            </form>
        </div>
    </div>
</section>
<partial name="_ValidationScriptsPartial" />
