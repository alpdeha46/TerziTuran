@model CompleteActivationViewModel
@{
    ViewData["Title"] = "Aktivasyon ve Yeni Sifre";
}
<section class="auth-shell">
    <div class="auth-card single">
        <div class="auth-form-panel w-100">
            <img class="auth-form-logo" src="~/images/terzituran-mark.svg" alt="" />
            <h2>Tek Kullanimlik Kod</h2>
            <p class="text-secondary">Yoneticiden aldiginiz aktivasyon kodunu girin ve yeni sifrenizi olusturun.</p>
            <form asp-action="CompleteActivation" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <input asp-for="UserId" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="col-12"><label asp-for="Username" class="form-label"></label><input asp-for="Username" class="form-control" autocomplete="username" /></div>
                <div class="col-12"><label asp-for="Code" class="form-label"></label><input asp-for="Code" class="form-control" autocomplete="one-time-code" placeholder="Orn: A2B4C6" /><span asp-validation-for="Code" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="NewPassword" class="form-label"></label><input asp-for="NewPassword" class="form-control" autocomplete="new-password" /><span asp-validation-for="NewPassword" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="ConfirmPassword" class="form-label"></label><input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" /><span asp-validation-for="ConfirmPassword" class="text-danger"></span></div>
                <div class="col-12 security-note"><i class="fa-solid fa-shield-halved"></i> Kod 15 dakika gecerlidir ve ilk dogrulamada kapanir.</div>
                <div class="col-12 d-grid"><button class="btn btn-gold">Kodu Dogrula ve Giris Yap</button></div>
                <div class="col-12 text-center"><a asp-action="Login">Giris ekranina don</a></div>
            </form>
        </div>
    </div>
</section>
<partial name="_ValidationScriptsPartial" />
