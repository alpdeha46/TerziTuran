@using TerziTuran.Web.Extensions
@model OrderDetailsViewModel
@{ ViewData["Title"] = "Sipariş Detayı"; }
<div class="row g-4">
    <div class="col-lg-5">
        <div class="card soft-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <span class="type-badge @(Model.Order.ServiceType == OrderServiceType.Sewing ? "type-sewing" : "type-repair")">@Model.Order.ServiceType.GetDisplayName()</span>
                    <h4 class="mt-3 mb-1">@Model.Order.Title</h4>
                    <div class="text-secondary">@Model.Order.Category</div>
                </div>
                <span class="status-badge @Model.Order.Status.ToString().ToLower()">@Model.Order.Status.GetDisplayName()</span>
            </div>
            <p>@Model.Order.Description</p>
            <div class="detail-grid">
                <div><span>Fiyat</span><strong>@Model.Order.Price.ToString("N0") TL</strong></div>
                <div><span>Ödenen</span><strong>@Model.Order.PaidAmount.ToString("N0") TL</strong></div>
                <div><span>Kalan</span><strong>@((Model.Order.Price - Model.Order.PaidAmount).ToString("N0")) TL</strong></div>
                <div><span>Teslim</span><strong>@Model.Order.DeliveryDate.ToString("dd.MM.yyyy")</strong></div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card soft-card">
            <h5>Sipariş Kalemleri</h5>
            @if (Model.OrderItems.Any())
            {
                <table class="table tt-table">
                    <thead><tr><th>Ürün</th><th>Adet</th><th>Birim</th><th>Tutar</th></tr></thead>
                    <tbody>@foreach (var item in Model.OrderItems) { <tr><td>@item.ProductName</td><td>@item.Quantity</td><td>@item.UnitPrice.ToString("N0") TL</td><td>@item.TotalPrice.ToString("N0") TL</td></tr> }</tbody>
                </table>
            }
            else
            {
                <div class="empty-state small-empty">Atölye henüz sipariş kalemlerini netleştirmedi.</div>
            }
            <h5 class="mt-4">Poşet Fişleri</h5>
            @if (Model.BagReceipts.Any())
            {
                <table class="table tt-table">
                    <thead><tr><th>Poşet No</th><th>Fiş No</th><th>Teslim Kodu</th><th>Poşet</th><th>Durum</th></tr></thead>
                    <tbody>@foreach (var item in Model.BagReceipts) { <tr><td><span class="pickup-code">@item.BagNumber</span></td><td>@item.ReceiptNumber</td><td><span class="pickup-code">@item.PickupCode</span></td><td>@item.BagCount</td><td>@(item.IsDelivered ? "Teslim Edildi" : "Teslim İçin Bekliyor")</td></tr> }</tbody>
                </table>
            }
            else
            {
                <div class="empty-state small-empty">Bu sipariş için henüz teslim fişi oluşturulmadı.</div>
            }
            <h5 class="mt-4">Ödeme Geçmişi</h5>
            @if (Model.Payments.Any())
            {
                <table class="table tt-table">
                    <thead><tr><th>Tarih</th><th>Tip</th><th>Tutar</th></tr></thead>
                    <tbody>@foreach (var item in Model.Payments) { <tr><td>@item.PaymentDate.ToString("dd.MM.yyyy")</td><td>@item.PaymentType.GetDisplayName()</td><td>@item.Amount.ToString("N0") TL</td></tr> }</tbody>
                </table>
            }
            else
            {
                <div class="empty-state small-empty">Henüz ödeme hareketi bulunmuyor.</div>
            }
        </div>
    </div>
</div>
