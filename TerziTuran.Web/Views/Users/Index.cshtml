@model UsersIndexViewModel
@{
    ViewData["Title"] = "Kullanicilar";
}

<div class="d-flex justify-content-end mb-3">
    <a asp-action="Create" class="btn btn-gold">Yeni Kullanici</a>
</div>

<div class="card soft-card">
    <table class="table table-dark table-hover align-middle">
        <thead>
            <tr>
                <th>Ad Soyad</th>
                <th>Kullanici</th>
                <th>Rol</th>
                <th>Telefon</th>
                <th>Durum</th>
                <th>Ilk Giris</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Users)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Username</td>
                <td>@item.Role</td>
                <td>@item.Phone</td>
                <td>@(item.IsActive ? "Aktif" : "Pasif")</td>
                <td>@(item.MustChangePassword ? "Kod Bekliyor" : "Tamamlandi")</td>
                <td class="text-end">
                    <form asp-action="ToggleActive" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-outline-info">Aktif/Pasif</button>
                    </form>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Duzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
