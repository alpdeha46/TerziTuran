@model Appointment
<div class="card soft-card"><form method="post" class="row g-3">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="col-md-4"><label class="form-label">Müşteri</label><select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-select"></select></div><div class="col-md-4"><label class="form-label">Sipariş</label><select asp-for="OrderId" asp-items="ViewBag.Orders" class="form-select"><option value="">Sipariş yok</option></select></div><div class="col-md-4"><label asp-for="AppointmentDate" class="form-label"></label><input asp-for="AppointmentDate" type="datetime-local" class="form-control" value="@Model.AppointmentDate.ToString("yyyy-MM-ddTHH:mm")" /></div><div class="col-md-6"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" placeholder="Örn: Son prova" /></div><div class="col-md-6"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<AppointmentStatus>()" class="form-select"></select></div><div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" placeholder="Kontrol edilecek ölçü veya prova ayrıntıları"></textarea></div><div class="col-12 d-flex gap-2"><button class="btn btn-gold">Kaydet</button><a asp-action="Index" class="btn btn-outline-dark">İptal</a></div></form></div><partial name="_ValidationScriptsPartial" />
