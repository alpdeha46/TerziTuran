@using TerziTuran.Web.Extensions
@model ReportsFilterViewModel
@{ ViewData["Title"] = "Raporlar"; }
<div class="card soft-card mb-4">
    <form class="row g-3">
        <div class="col-md-2"><label class="form-label">Başlangıç</label><input asp-for="StartDate" type="date" class="form-control" /></div>
        <div class="col-md-2"><label class="form-label">Bitiş</label><input asp-for="EndDate" type="date" class="form-control" /></div>
        <div class="col-md-2"><label class="form-label">Müşteri</label><select asp-for="CustomerId" class="form-select"><option value="">Tüm Müşteriler</option>@foreach (var c in Model.Customers) { <option selected="@(Model.CustomerId==c.Id)" value="@c.Id">@c.FullName</option> }</select></div>
        <div class="col-md-2"><label class="form-label">Durum</label><select asp-for="OrderStatus" asp-items="Html.GetEnumSelectList<OrderStatus>()" class="form-select"><option value="">Tüm Durumlar</option></select></div>
        <div class="col-md-2"><label class="form-label">Ödeme</label><select asp-for="PaymentStatus" class="form-select"><option value="">Tüm Durumlar</option><option value="Unpaid">Ödenmedi</option><option value="PartiallyPaid">Kısmen Ödendi</option><option value="Paid">Ödendi</option></select></div>
        <div class="col-md-2"><label class="form-label">Kategori</label><input asp-for="Category" class="form-control" /></div>
        <div class="col-12 d-flex gap-2 flex-wrap"><button class="btn btn-gold">Filtrele</button><a asp-action="Reset" class="btn btn-outline-light">Sıfırla</a><a asp-action="DownloadPdf" asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")" asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")" asp-route-CustomerId="@Model.CustomerId" asp-route-OrderStatus="@Model.OrderStatus" asp-route-PaymentStatus="@Model.PaymentStatus" asp-route-Category="@Model.Category" class="btn btn-outline-warning">PDF İndir</a><button type="button" onclick="window.print()" class="btn btn-outline-info">Yazdır</button></div>
    </form>
</div>
<div class="card soft-card">
    <div class="d-flex justify-content-between mb-3 flex-wrap gap-2"><strong>Toplam @Model.Rows.Count kayıt</strong><span>Tutar: @Model.Rows.Sum(x=>x.Price).ToString("N0") TL | Tahsilat: @Model.Rows.Sum(x=>x.PaidAmount).ToString("N0") TL | Kalan: @Model.Rows.Sum(x=>x.RemainingAmount).ToString("N0") TL</span></div>
    <div class="table-responsive">
        <table class="table tt-table table-hover">
            <thead><tr><th>Müşteri</th><th>Hizmet</th><th>Sipariş</th><th>Kategori</th><th>Durum</th><th>Oluşturan</th><th>Fiyat</th><th>Ödenen</th><th>Kalan</th><th>Teslim</th><th>Oluşturma</th></tr></thead>
            <tbody>@foreach (var item in Model.Rows) { <tr><td data-label="Müşteri">@item.CustomerName</td><td data-label="Hizmet">@item.ServiceType</td><td data-label="Sipariş">@item.OrderTitle</td><td data-label="Kategori">@item.Category</td><td data-label="Durum">@item.Status</td><td data-label="Oluşturan">@item.CreatedBy</td><td data-label="Fiyat">@item.Price.ToString("N0")</td><td data-label="Ödenen">@item.PaidAmount.ToString("N0")</td><td data-label="Kalan">@item.RemainingAmount.ToString("N0")</td><td data-label="Teslim">@item.DeliveryDate.ToString("dd.MM.yyyy")</td><td data-label="Oluşturma">@item.CreatedDate.ToString("dd.MM.yyyy")</td></tr> }</tbody>
        </table>
    </div>
</div>
