@model ChangePasswordViewModel
@{ ViewData["Title"] = "Şifre Değiştir"; }
<div class="card soft-card"><form method="post" class="row g-3">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="col-md-4"><label asp-for="CurrentPassword" class="form-label"></label><input asp-for="CurrentPassword" class="form-control" /></div><div class="col-md-4"><label asp-for="NewPassword" class="form-label"></label><input asp-for="NewPassword" class="form-control" /></div><div class="col-md-4"><label asp-for="ConfirmPassword" class="form-label"></label><input asp-for="ConfirmPassword" class="form-control" /></div><div class="col-12 d-flex gap-2"><button class="btn btn-gold">Güncelle</button><a asp-action="Index" class="btn btn-outline-dark">İptal</a></div></form></div><partial name="_ValidationScriptsPartial" />
