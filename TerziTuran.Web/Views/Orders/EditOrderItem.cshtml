@model OrderItem
@{ ViewData["Title"] = "Siparis Kalemi Duzenle"; }
<div class="card soft-card"><form method="post" class="row g-3">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><input asp-for="OrderId" type="hidden" /><div class="col-md-6"><label asp-for="ProductName" class="form-label"></label><input asp-for="ProductName" class="form-control" /></div><div class="col-md-3"><label asp-for="Quantity" class="form-label"></label><input asp-for="Quantity" class="form-control" /></div><div class="col-md-3"><label asp-for="UnitPrice" class="form-label"></label><input asp-for="UnitPrice" class="form-control" /></div><div class="col-12 d-flex gap-2"><button class="btn btn-gold">Kaydet</button><a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-light">Geri Don</a></div></form></div><partial name="_ValidationScriptsPartial" />
